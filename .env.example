AR_BASE_URL=http://ars-arserver:8008
SESSION_SECRET=change-me-to-a-long-random-string
LOG_LEVEL=INFO
CONFIG_PATH=/app/config.yaml

DATA_DIR=/data
RETENTION_DAYS=5

REQUIRE_ADMIN_GROUP=true
AR_ADMIN_GROUP_ID=1
AR_USER_FORM=User
AR_LOGIN_FIELD=Login Name
AR_GROUP_LIST_FIELD=Group List
AR_COLLECT_CONCURRENCY=4

DISCOVERY_ENABLED=true
DISCOVERY_REFRESH_INTERVAL_SECONDS=300
DISCOVERY_POD_FORM_NAME=AR System Configuration Component Setting
DISCOVERY_POD_QUERY='Setting Name' = "Configuration-Name"
DISCOVERY_POD_VALUE_FIELD=Setting Value
DISCOVERY_LOG_FORM_NAME=AR System Server Group Logs
DISCOVERY_LOG_SERVER_FIELD=Server Name
DISCOVERY_LOG_FILENAME_FIELD=fileName
DISCOVERY_LOG_SIZE_FIELD=File Size
DISCOVERY_DEFAULT_DIRECTORY=/opt/bmc/ARSystem/db
DISCOVERY_INCLUDE_ZERO_BYTE_LOGS=true
